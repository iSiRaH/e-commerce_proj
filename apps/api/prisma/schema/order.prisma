model Order {
    orderId         Int          @id @default(autoincrement())
    userId          Int
    orderItems      Product[]
    totalAmount     Float
    discount        Float?
    tax             Float?
    shippingAddress String?
    billingAddress  String?
    shippingMethod  String?
    paymentMethod   String?
    paymentStatus   String?
    orderStatus     String
    shippingCost    Float?
    subtotal        Float
    status          String
    createdAt       DateTime     @default(now())
    updatedAt       DateTime     @updatedAt
}

